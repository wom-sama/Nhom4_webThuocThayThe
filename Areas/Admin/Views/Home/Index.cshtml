@model Nhom4WebThuocThayThe.ViewModels.Reports.DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan quản trị";
}

<section class="mb-4"><div class="page-kicker">Khu vực quản trị</div><h1 class="page-title">Vận hành hệ thống</h1><p class="page-description">Quản trị danh mục, kho, nguồn dữ liệu, audit và khả năng khôi phục.</p></section>

<section class="quick-action-grid quick-action-grid-admin mb-4" aria-label="Tác vụ quản trị">
    <a asp-controller="DrugCatalog" asp-action="Index" class="quick-action"><i data-lucide="library" class="quick-action-icon" aria-hidden="true"></i><span><strong>Danh mục thuốc</strong><small>Cập nhật dữ liệu chuẩn</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i></a>
    <a asp-controller="Inventory" asp-action="Index" class="quick-action"><i data-lucide="warehouse" class="quick-action-icon" aria-hidden="true"></i><span><strong>Kho và lô thuốc</strong><small>Xử lý ngoại lệ tồn kho</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i></a>
    <a asp-controller="ExternalData" asp-action="Index" class="quick-action"><i data-lucide="database-zap" class="quick-action-icon" aria-hidden="true"></i><span><strong>Nguồn dữ liệu</strong><small>Kiểm tra trạng thái đồng bộ</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i></a>
    <a asp-controller="Reports" asp-action="Index" class="quick-action"><i data-lucide="history" class="quick-action-icon" aria-hidden="true"></i><span><strong>Backup và audit</strong><small>Snapshot và lịch sử thao tác</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i></a>
</section>

<section class="metric-grid mb-4" aria-label="Chỉ số quản trị">
    @foreach (var metric in Model.Metrics)
    {
        <article class="metric-card"><div class="metric-label"><i data-lucide="activity" class="app-icon" aria-hidden="true"></i><span>@metric.Label</span></div><strong>@metric.Value</strong><span>@metric.Hint</span></article>
    }
</section>

<section id="roles" class="app-surface role-boundary-note"><i data-lucide="shield-check" class="quick-action-icon" aria-hidden="true"></i><div><h2 class="h5">Phân quyền theo khu vực</h2><p class="muted-copy mb-0">Admin, Dược sĩ, Chuyên gia và Người dùng có shell nghiệp vụ riêng; server vẫn kiểm soát mọi quyền truy cập.</p></div></section>
