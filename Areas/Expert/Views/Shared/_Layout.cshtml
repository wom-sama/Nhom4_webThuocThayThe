<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khu vực chuyên gia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /><link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="role-shell role-expert ui-v3">
    <a class="skip-link" href="#main-content">@T["Common.SkipNavigation"]</a>
    <div class="role-layout">
        <aside class="role-sidebar" aria-label="Điều hướng chuyên gia">
            <a class="role-brand" asp-area="Expert" asp-controller="Home" asp-action="Index"><span>Rx</span><strong>Chuyên gia</strong></a>
            <nav class="role-nav"><a asp-area="Expert" asp-controller="Home" asp-action="Index"><i data-lucide="layout-dashboard" class="app-icon" aria-hidden="true"></i>Tổng quan</a><a asp-area="Expert" asp-controller="Reviews" asp-action="Index"><i data-lucide="clipboard-list" class="app-icon" aria-hidden="true"></i>Hàng chờ đánh giá</a><a asp-area="Expert" asp-controller="Reviews" asp-action="Evidence"><i data-lucide="book-open-check" class="app-icon" aria-hidden="true"></i>Bằng chứng</a><a asp-area="Expert" asp-controller="Reviews" asp-action="History"><i data-lucide="history" class="app-icon" aria-hidden="true"></i>Lịch sử quyết định</a></nav>
            <div class="role-user-panel"><strong>@User.Identity?.Name</strong><span>Chuyên gia y tế</span><form asp-area="" asp-controller="Auth" asp-action="Logout" method="post"><button type="submit"><i data-lucide="log-out" class="app-icon" aria-hidden="true"></i>Đăng xuất</button></form></div>
        </aside>
        <div class="role-content"><header class="role-topbar"><span>Không gian đánh giá chuyên môn</span><div class="role-topbar-actions"><a asp-area="" asp-controller="Drugs" asp-action="Index">Tra cứu công khai</a><form class="role-mobile-logout" asp-area="" asp-controller="Auth" asp-action="Logout" method="post"><button type="submit" aria-label="Đăng xuất"><i data-lucide="log-out" class="app-icon" aria-hidden="true"></i><span>Đăng xuất</span></button></form></div></header><main id="main-content" class="role-main">@RenderBody()</main></div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script><script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script><script src="~/lib/lucide/lucide.min.js"></script><script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
