@{
    ViewData["Title"] = "Tổng quan cá nhân";
}

<section class="workspace-heading mb-4">
    <div class="page-kicker"><span class="live-dot" aria-hidden="true"></span>Khu vực người dùng</div>
    <h1 class="page-title">Chào @User.Identity?.Name</h1>
</section>

<section class="quick-action-grid mb-4" aria-label="Bắt đầu nhanh">
    <a asp-area="" asp-controller="Drugs" asp-action="Index" class="quick-action">
        <i data-lucide="search" class="quick-action-icon" aria-hidden="true"></i><span><strong>Tra cứu thuốc</strong><small>Tìm theo tên hoặc hoạt chất</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i>
    </a>
    <a asp-action="History" class="quick-action">
        <i data-lucide="history" class="quick-action-icon" aria-hidden="true"></i><span><strong>Lịch sử tra cứu</strong><small>Xem lại kết quả trước đây</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i>
    </a>
    <a asp-action="Saved" class="quick-action">
        <i data-lucide="bookmark" class="quick-action-icon" aria-hidden="true"></i><span><strong>Thuốc đã lưu</strong><small>Theo dõi danh sách cá nhân</small></span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i>
    </a>
</section>

<section class="metric-grid" aria-label="Tổng quan cá nhân">
    <article class="metric-card"><div class="metric-label"><i data-lucide="clock-3" class="app-icon" aria-hidden="true"></i><span>Lượt tra cứu</span></div><strong>0</strong><span>Chưa có lịch sử trong phiên bản này</span></article>
    <article class="metric-card"><div class="metric-label"><i data-lucide="bookmark-check" class="app-icon" aria-hidden="true"></i><span>Thuốc đã lưu</span></div><strong>0</strong><span>Sẵn sàng cho dữ liệu cá nhân</span></article>
    <article class="metric-card"><div class="metric-label"><i data-lucide="bell" class="app-icon" aria-hidden="true"></i><span>Thông báo tồn kho</span></div><strong>0</strong><span>Không có thông báo mới</span></article>
    <article class="metric-card"><div class="metric-label"><i data-lucide="shield-check" class="app-icon" aria-hidden="true"></i><span>Phiên hiện tại</span></div><strong>Đang hoạt động</strong><span>Tự hết hạn khi không hoạt động</span></article>
</section>

<div class="safety-note mt-4"><i data-lucide="triangle-alert" class="app-icon" aria-hidden="true"></i><span>Thông tin chỉ hỗ trợ tra cứu, không thay thế tư vấn và đơn thuốc.</span></div>
