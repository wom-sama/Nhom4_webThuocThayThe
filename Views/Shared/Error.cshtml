@model ErrorViewModel
@{
    ViewData["Title"] = "Có lỗi xảy ra";
}

<section class="app-surface access-panel">
    <div class="page-kicker">Không thể hoàn tất yêu cầu</div>
    <h1 class="page-title">Hệ thống đang gặp sự cố</h1>
    <p class="page-description">Vui lòng thử lại sau. Thông tin kỹ thuật chi tiết không được hiển thị để bảo vệ hệ thống.</p>
    @if (Model.ShowRequestId)
    {
        <p class="mt-3 mb-0"><strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code></p>
    }
</section>
