@model Nhom4WebThuocThayThe.ViewModels.Auth.LoginViewModel

@{
    ViewData["Title"] = "Dang nhap";
}

<section class="auth-layout">
    <div>
        <div class="page-kicker">Phien lam viec</div>
        <h1 class="page-title">Dang nhap he thong</h1>
        <p class="page-description">Tai khoan duoc gan vai tro de mo dung chuc nang: quan tri danh muc, quan ly kho, review chuyen mon hoac tra cuu cong khai.</p>
        <div class="account-list">
            <span>admin@nhom4.local / Admin@123</span>
            <span>duocsi@nhom4.local / Duocsi@123</span>
            <span>chuyengia@nhom4.local / Chuyengia@123</span>
            <span>user@nhom4.local / User@123</span>
        </div>
    </div>

    <form asp-action="Login" method="post" class="app-surface auth-panel">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" autocomplete="username" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Dang nhap</button>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
