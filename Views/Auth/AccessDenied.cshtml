@{
    ViewData["Title"] = T["AccessDenied.Title"];
}

<section class="app-surface access-panel">
    <div class="page-kicker">@T["AccessDenied.Kicker"]</div>
    <h1 class="page-title">@T["AccessDenied.Heading"]</h1>
    <p class="page-description">@T["AccessDenied.Description"]</p>
    <div class="d-flex flex-wrap gap-2">
        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary">@T["Navigation.Overview"]</a>
        <a asp-area="" asp-controller="Drugs" asp-action="Index" class="btn btn-outline-primary">@T["Navigation.DrugSearch"]</a>
    </div>
</section>
