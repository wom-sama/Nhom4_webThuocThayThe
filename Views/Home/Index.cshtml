@model Nhom4WebThuocThayThe.ViewModels.Home.HomeDashboardViewModel

@{
    ViewData["Title"] = "Tổng quan";
}

<section class="page-intro mb-4">
    <div class="page-kicker">Tra cứu thuốc thay thế</div>
    <h1 class="page-title">Tìm thuốc và phương án thay thế</h1>
    <p class="page-description">
        Nhập tên thuốc hoặc hoạt chất để kiểm tra tồn kho, cảnh báo và lựa chọn thay thế phù hợp.
    </p>
</section>

<section class="app-surface search-surface mb-4" aria-labelledby="public-search-heading">
    <div class="section-heading search-heading">
        <div>
            <h2 id="public-search-heading" class="h4">Tìm thuốc</h2>
        </div>
    </div>
    <form asp-controller="Drugs" asp-action="Index" method="get" class="quick-search">
        <div>
            <label for="homeKeyword" class="form-label">Tên thuốc hoặc hoạt chất</label>
            <input id="homeKeyword" name="keyword" class="form-control form-control-lg" placeholder="Ví dụ: Paracetamol" autocomplete="off" />
        </div>
        <div>
            <label for="homeCategory" class="form-label">Nhóm thuốc</label>
            <select id="homeCategory" name="categoryId" class="form-select form-select-lg">
                <option value="">Tất cả nhóm thuốc</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Value">@category.Text</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-lg icon-button-label">
            <i data-lucide="search" class="app-icon" aria-hidden="true"></i>
            <span>Tra cứu</span>
        </button>
    </form>
</section>

<section class="metric-strip mb-4" aria-label="Thông tin hệ thống">
    <article class="metric-card metric-card-compact">
        <div class="metric-label"><i data-lucide="pill" class="app-icon" aria-hidden="true"></i><span>Thuốc có dữ liệu</span></div>
        <strong>@Model.DrugCount</strong>
    </article>
    <article class="metric-card metric-card-compact">
        <div class="metric-label"><i data-lucide="list-filter" class="app-icon" aria-hidden="true"></i><span>Nhóm điều trị</span></div>
        <strong>@Model.CategoryCount</strong>
    </article>
    <article class="metric-card metric-card-compact">
        <div class="metric-label"><i data-lucide="package-check" class="app-icon" aria-hidden="true"></i><span>Lô đang theo dõi</span></div>
        <strong>@Model.BatchCount</strong>
    </article>
    <article class="metric-card metric-card-compact metric-card-alert">
        <div class="metric-label"><i data-lucide="package-x" class="app-icon" aria-hidden="true"></i><span>Thuốc tạm hết</span></div>
        <strong>@Model.StockoutCount</strong>
    </article>
</section>
