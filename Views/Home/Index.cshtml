@{
    ViewData["Title"] = "Tong quan";
}

<section class="mb-4">
    <div class="page-kicker">He thong de xuat thuoc thay the</div>
    <h1 class="page-title">Bang dieu khien tra cuu va quan ly thuoc</h1>
    <p class="page-description">
        Tap trung vao tra cuu thuoc, tinh trang ton kho va cac du lieu nen tang can cho quy trinh de xuat thuoc thay the khi thuoc chinh khong co san.
    </p>
</section>

<section class="app-surface mb-4">
    <form asp-controller="Drugs" asp-action="Index" method="get" class="quick-search">
        <div>
            <label for="homeKeyword" class="form-label">Tu khoa tra cuu</label>
            <input id="homeKeyword" name="keyword" class="form-control form-control-lg" placeholder="Panadol, Paracetamol, khang sinh..." />
        </div>
        <div>
            <label for="homeCategory" class="form-label">Pham vi</label>
            <select id="homeCategory" class="form-select form-select-lg" disabled>
                <option>Ten thuoc, hoat chat, danh muc</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary btn-lg">Tim</button>
    </form>
</section>

<section class="metric-grid mb-4" aria-label="Chi so mau">
    <div class="metric-card">
        <span>Thuoc dang quan ly</span>
        <strong>@ViewBag.DrugCount</strong>
        <span>Co hoat chat va thong tin duoc ly</span>
    </div>
    <div class="metric-card">
        <span>Danh muc</span>
        <strong>@ViewBag.CategoryCount</strong>
        <span>Phan loai phuc vu tra cuu</span>
    </div>
    <div class="metric-card">
        <span>Lo thuoc</span>
        <strong>@ViewBag.BatchCount</strong>
        <span>Co theo doi han su dung</span>
    </div>
    <div class="metric-card">
        <span>Thuoc het hang</span>
        <strong>@ViewBag.StockoutCount</strong>
        <span>Can kich hoat de xuat thay the</span>
    </div>
</section>

<section class="workflow-grid">
    <article class="workflow-card">
        <h2 class="h5">Tra cuu</h2>
        <p>Tim thuoc theo ten, hoat chat hoac danh muc va kiem tra ton kho hien tai.</p>
        <a asp-controller="Drugs" asp-action="Index" class="btn btn-outline-primary btn-sm">Mo tra cuu</a>
    </article>
    <article class="workflow-card">
        <h2 class="h5">Danh muc</h2>
        <p>Quan ly du lieu thuoc, hoat chat, dang bao che va thong tin canh bao.</p>
        <a asp-controller="DrugCatalog" asp-action="Index" class="btn btn-outline-primary btn-sm">Mo danh muc</a>
    </article>
    <article class="workflow-card">
        <h2 class="h5">Kho thuoc</h2>
        <p>Theo doi lo thuoc kha dung, so luong ton va trang thai het hang.</p>
        <a asp-controller="Inventory" asp-action="Index" class="btn btn-outline-primary btn-sm">Mo kho</a>
    </article>
    <article class="workflow-card">
        <h2 class="h5">Danh gia de xuat</h2>
        <p>Chuyen gia xem score, ly do va xac nhan de xuat truoc khi tu van.</p>
        <a asp-controller="ExpertReviews" asp-action="Index" class="btn btn-outline-primary btn-sm">Mo danh gia</a>
    </article>
    <article class="workflow-card">
        <h2 class="h5">Bao cao</h2>
        <p>Theo doi rui ro ton kho, audit log, nguon du lieu va backup metadata.</p>
        <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-primary btn-sm">Mo bao cao</a>
    </article>
</section>
