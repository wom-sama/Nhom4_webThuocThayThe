@model Nhom4WebThuocThayThe.ViewModels.Reports.DashboardViewModel

@{
    ViewData["Title"] = "Báo cáo vận hành";
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Vận hành và báo cáo</div>
        <h1 class="page-title">Tổng quan hệ thống thuốc thay thế</h1>
        <p class="page-description">Theo dõi tồn kho, nguồn dữ liệu, cảnh báo và lịch sử thao tác của hệ thống.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <form asp-action="DownloadBackup" method="post">
            <button type="submit" class="btn btn-outline-primary">Tải bản sao lưu JSON</button>
        </form>
    }
</section>

<section class="metric-grid mb-4" aria-label="Chỉ số hệ thống">
    @foreach (var metric in Model.Metrics)
    {
        <article class="metric-card">
            <span>@metric.Label</span>
            <strong>@metric.Value</strong>
            <span>@metric.Hint</span>
        </article>
    }
</section>

<section class="report-grid mb-4">
    <div class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Rủi ro tồn kho</h2>
            <span class="muted-copy">@Model.StockRisks.Count thuốc</span>
        </div>
        <div class="table-shell">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Thuốc</th>
                        <th>Hàm lượng</th>
                        <th>Số lượng</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.StockRisks)
                    {
                        var statusClass = item.RiskLevel == "Het hang" ? "is-danger" : item.RiskLevel == "Can nhap them" ? "is-warning" : "is-success";
                        var riskLabel = item.RiskLevel == "Het hang" ? "Hết hàng" : item.RiskLevel == "Can nhap them" ? "Cần nhập thêm" : "Ổn định";
                        <tr>
                            <td><strong>@item.DrugName</strong></td>
                            <td>@item.Strength</td>
                            <td>@item.Quantity</td>
                            <td><span class="status-badge @statusClass">@riskLabel</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <aside class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Bản sao lưu gần nhất</h2>
            <span class="status-badge is-info">Siêu dữ liệu</span>
        </div>
        <dl class="detail-list">
            <div class="detail-row">
                <dt>Thời điểm</dt>
                <dd>@Model.BackupSnapshot.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</dd>
            </div>
            <div class="detail-row">
                <dt>Thuốc</dt>
                <dd>@Model.BackupSnapshot.DrugCount</dd>
            </div>
            <div class="detail-row">
                <dt>Lô thuốc</dt>
                <dd>@Model.BackupSnapshot.BatchCount</dd>
            </div>
            <div class="detail-row">
                <dt>Audit log</dt>
                <dd>@Model.BackupSnapshot.AuditLogCount</dd>
            </div>
            <div class="detail-row">
                <dt>Nguồn ngoài</dt>
                <dd>@Model.BackupSnapshot.ExternalSourceCount</dd>
            </div>
        </dl>
    </aside>
</section>

<section class="app-surface mb-4">
    <div class="section-heading">
        <h2 class="h4">Nguồn dữ liệu ngoài</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="ExternalData" asp-action="Index" class="btn btn-sm btn-outline-primary">Quản lý nguồn</a>
        }
    </div>
    <div class="source-grid">
        @foreach (var source in Model.ExternalSources)
        {
            <article class="source-card">
                <strong>@source.Name</strong>
                <span>@source.Purpose</span>
                <span class="status-badge is-info">@source.MappingStatus</span>
                <small>Đồng bộ: @(source.LastSyncDate?.ToString("dd/MM/yyyy") ?? "Chưa có")</small>
            </article>
        }
    </div>
</section>

<section class="app-surface">
    <div class="section-heading">
        <h2 class="h4">Nhật ký kiểm toán gần đây</h2>
        <span class="muted-copy">@Model.AuditLogs.Count bản ghi</span>
    </div>
    <div class="timeline-list">
        @foreach (var log in Model.AuditLogs)
        {
            <article>
                <div>
                    <strong>@log.Action - @log.Entity</strong>
                    <span>@log.Detail</span>
                </div>
                <small>@log.Actor · @log.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</small>
            </article>
        }
    </div>
</section>
