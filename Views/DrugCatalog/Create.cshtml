@model Nhom4WebThuocThayThe.ViewModels.Catalog.DrugFormViewModel

@{
    ViewData["Title"] = "Thêm thuốc";
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Danh mục thuốc</div>
        <h1 class="page-title">Thêm thuốc</h1>
    </div>
</section>

<form asp-action="Create" method="post" class="app-surface">
    <partial name="/Views/DrugCatalog/_DrugForm.cshtml" model="Model" />
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
