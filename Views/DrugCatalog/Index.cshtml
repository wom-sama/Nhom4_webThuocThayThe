@model IReadOnlyCollection<Nhom4WebThuocThayThe.ViewModels.Catalog.DrugListItemViewModel>

@{
    ViewData["Title"] = "Danh mục thuốc";
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Quản trị dữ liệu</div>
        <h1 class="page-title">Danh mục thuốc</h1>
        <p class="page-description">Cập nhật thông tin thuốc, hàm lượng, nhà sản xuất, cảnh báo kê đơn và trạng thái kinh doanh.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Thêm thuốc</a>
</section>

<div class="table-shell">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Tên thuốc</th>
                <th>Danh mục</th>
                <th>Nhà sản xuất</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <strong>@item.Name</strong>
                        <div class="drug-meta">@item.Strength - @item.DosageForm</div>
                    </td>
                    <td>@item.Category</td>
                    <td>@item.Manufacturer</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>
                        @if (item.StockQuantity <= 0)
                        {
                            <span class="status-badge is-danger">Hết hàng</span>
                        }
                        else
                        {
                            <span class="status-badge is-success">@item.StockQuantity</span>
                        }
                    </td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="status-badge is-info">Đang bán</span>
                        }
                        else
                        {
                            <span class="status-badge is-warning">Ngừng bán</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
