@model IReadOnlyCollection<Nhom4WebThuocThayThe.Models.ExternalDataSource>

@{
    ViewData["Title"] = "Nguồn dữ liệu ngoài";
}

<section class="mb-4">
    <div class="page-kicker">Tích hợp dữ liệu</div>
    <h1 class="page-title">Quản lý nguồn dữ liệu dược ngoài</h1>
    <p class="page-description">Theo dõi mục đích, ánh xạ và lần đồng bộ siêu dữ liệu của từng nguồn tham chiếu.</p>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="source-grid">
    @foreach (var source in Model)
    {
        <article class="app-surface source-admin-card">
            <div class="section-heading">
                <div>
                    <h2 class="h5">@source.Name</h2>
                    <a href="@source.SourceUrl" target="_blank" rel="noopener noreferrer">@source.SourceUrl</a>
                </div>
                <span class="status-badge is-info">@source.MappingStatus</span>
            </div>
            <p>@source.Purpose</p>
            <div class="action-bar mb-0">
                <span class="muted-copy">Lần đồng bộ: @(source.LastSyncDate?.ToString("dd/MM/yyyy") ?? "Chưa có")</span>
                <form asp-action="MarkSynced" method="post">
                    <input type="hidden" name="id" value="@source.Id" />
                    <button type="submit" class="btn btn-sm btn-primary">Đánh dấu đã đồng bộ</button>
                </form>
            </div>
        </article>
    }
</div>
