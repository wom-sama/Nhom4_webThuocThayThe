@model IReadOnlyCollection<Nhom4WebThuocThayThe.ViewModels.Inventory.StockSummaryViewModel>

@{
    ViewData["Title"] = "Kho thuoc";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Kho thuoc</h1>
    <a asp-action="CreateBatch" class="btn btn-primary">Them lo thuoc</a>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Thuoc</th>
            <th>Ham luong</th>
            <th>Ton kho kha dung</th>
            <th>Trang thai</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DrugName</td>
                <td>@item.Strength</td>
                <td>@item.Quantity</td>
                <td>
                    @if (item.IsOutOfStock)
                    {
                        <span class="badge text-bg-danger">Het hang</span>
                    }
                    else
                    {
                        <span class="badge text-bg-success">Con hang</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
