@using Nhom4WebThuocThayThe.ViewModels.Inventory
@model IReadOnlyCollection<Nhom4WebThuocThayThe.ViewModels.Inventory.StockSummaryViewModel>

@{
    ViewData["Title"] = "Kho thuoc";
    var batches = ViewBag.Batches as IReadOnlyCollection<BatchListItemViewModel> ?? Array.Empty<BatchListItemViewModel>();
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Quan ly kho</div>
        <h1 class="page-title">Ton kho va lo thuoc</h1>
        <p class="page-description">Theo doi so luong kha dung, lo het hang, lo qua han va lo can theo doi han su dung.</p>
    </div>
    <a asp-action="CreateBatch" class="btn btn-primary">+ Them lo thuoc</a>
</section>

<section class="metric-grid mb-4" aria-label="Tong quan kho">
    <div class="metric-card">
        <span>Mat hang</span>
        <strong>@Model.Count</strong>
        <span>Thuoc dang quan ly</span>
    </div>
    <div class="metric-card">
        <span>Lo thuoc</span>
        <strong>@batches.Count</strong>
        <span>Theo kho va han su dung</span>
    </div>
    <div class="metric-card">
        <span>Het hang</span>
        <strong>@Model.Count(item => item.IsOutOfStock)</strong>
        <span>Can de xuat thay the</span>
    </div>
    <div class="metric-card">
        <span>Can han</span>
        <strong>@batches.Count(item => item.IsNearExpiry)</strong>
        <span>Trong 90 ngay</span>
    </div>
</section>

<section class="mb-4">
    <div class="section-heading">
        <h2 class="h4">Ton kho theo thuoc</h2>
    </div>
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Thuoc</th>
                    <th>Ham luong</th>
                    <th>Ton kho kha dung</th>
                    <th>Trang thai</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DrugName</td>
                        <td>@item.Strength</td>
                        <td>@item.Quantity</td>
                        <td>
                            @if (item.IsOutOfStock)
                            {
                                <span class="status-badge is-danger">Het hang</span>
                            }
                            else
                            {
                                <span class="status-badge is-success">Con hang</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section>
    <div class="section-heading">
        <h2 class="h4">Danh sach lo thuoc</h2>
    </div>
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>So lo</th>
                    <th>Thuoc</th>
                    <th>Kho</th>
                    <th>So luong</th>
                    <th>Ngay nhap</th>
                    <th>Han su dung</th>
                    <th>Trang thai</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in batches)
                {
                    <tr>
                        <td><strong>@item.BatchNumber</strong></td>
                        <td>
                            @item.DrugName
                            <div class="drug-meta">@item.Strength</div>
                        </td>
                        <td>@item.WarehouseName</td>
                        <td>@item.Quantity</td>
                        <td>@item.ImportedDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.ExpiryDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="status-badge @item.StatusCssClass">@item.StatusLabel</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
