@using Nhom4WebThuocThayThe.ViewModels.Inventory
@model IReadOnlyCollection<Nhom4WebThuocThayThe.ViewModels.Inventory.StockSummaryViewModel>

@{
    ViewData["Title"] = "Kho thuốc";
    var batches = ViewBag.Batches as IReadOnlyCollection<BatchListItemViewModel> ?? Array.Empty<BatchListItemViewModel>();
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Quản lý kho</div>
        <h1 class="page-title">Tồn kho và lô thuốc</h1>
        <p class="page-description">Theo dõi số lượng khả dụng, lô hết hàng, lô quá hạn và lô cần theo dõi hạn sử dụng.</p>
    </div>
    <a asp-action="CreateBatch" class="btn btn-primary">Thêm lô thuốc</a>
</section>

<section class="metric-grid mb-4" aria-label="Tổng quan kho">
    <div class="metric-card">
        <span>Mặt hàng</span>
        <strong>@Model.Count</strong>
        <span>Thuốc đang quản lý</span>
    </div>
    <div class="metric-card">
        <span>Lô thuốc</span>
        <strong>@batches.Count</strong>
        <span>Theo kho và hạn sử dụng</span>
    </div>
    <div class="metric-card">
        <span>Hết hàng</span>
        <strong>@Model.Count(item => item.IsOutOfStock)</strong>
        <span>Cần đề xuất thay thế</span>
    </div>
    <div class="metric-card">
        <span>Cận hạn</span>
        <strong>@batches.Count(item => item.IsNearExpiry)</strong>
        <span>Trong 90 ngày</span>
    </div>
</section>

<section class="mb-4">
    <div class="section-heading">
        <h2 class="h4">Tồn kho theo thuốc</h2>
    </div>
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Thuốc</th>
                    <th>Hàm lượng</th>
                    <th>Tồn kho khả dụng</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DrugName</td>
                        <td>@item.Strength</td>
                        <td>@item.Quantity</td>
                        <td>
                            @if (item.IsOutOfStock)
                            {
                                <span class="status-badge is-danger">Hết hàng</span>
                            }
                            else
                            {
                                <span class="status-badge is-success">Còn hàng</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section>
    <div class="section-heading">
        <h2 class="h4">Danh sách lô thuốc</h2>
    </div>
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Số lô</th>
                    <th>Thuốc</th>
                    <th>Kho</th>
                    <th>Số lượng</th>
                    <th>Ngày nhập</th>
                    <th>Hạn sử dụng</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in batches)
                {
                    <tr>
                        <td><strong>@item.BatchNumber</strong></td>
                        <td>
                            @item.DrugName
                            <div class="drug-meta">@item.Strength</div>
                        </td>
                        <td>@item.WarehouseName</td>
                        <td>@item.Quantity</td>
                        <td>@item.ImportedDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.ExpiryDate.ToString("dd/MM/yyyy")</td>
                        <td><span class="status-badge @item.StatusCssClass">@item.StatusLabel</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
