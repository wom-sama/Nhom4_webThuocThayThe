@model Nhom4WebThuocThayThe.ViewModels.Inventory.BatchFormViewModel

@{
    ViewData["Title"] = "Them lo thuoc";
}

<h1 class="h3 mb-3">Them lo thuoc</h1>
<form asp-action="CreateBatch" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="col-md-6">
        <label asp-for="DrugId" class="form-label">Thuoc</label>
        <select asp-for="DrugId" asp-items="Model.Drugs" class="form-select"></select>
    </div>
    <div class="col-md-6">
        <label asp-for="WarehouseId" class="form-label">Kho</label>
        <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="BatchNumber" class="form-label">So lo</label>
        <input asp-for="BatchNumber" class="form-control" />
        <span asp-validation-for="BatchNumber" class="text-danger"></span>
    </div>
    <div class="col-md-2">
        <label asp-for="Quantity" class="form-label">So luong</label>
        <input asp-for="Quantity" class="form-control" />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="ImportedDate" class="form-label">Ngay nhap</label>
        <input asp-for="ImportedDate" class="form-control" />
    </div>
    <div class="col-md-3">
        <label asp-for="ExpiryDate" class="form-label">Han su dung</label>
        <input asp-for="ExpiryDate" class="form-control" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Luu lo thuoc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Huy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
