@model Nhom4WebThuocThayThe.ViewModels.Inventory.BatchFormViewModel

@{
    ViewData["Title"] = "Thêm lô thuốc";
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Quản lý kho</div>
        <h1 class="page-title">Thêm lô thuốc</h1>
    </div>
</section>

<form asp-action="CreateBatch" method="post" class="app-surface">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="DrugId" class="form-label">Thuốc</label>
            <select asp-for="DrugId" asp-items="Model.Drugs" class="form-select"></select>
        </div>
        <div class="col-md-6">
            <label asp-for="WarehouseId" class="form-label">Kho</label>
            <select asp-for="WarehouseId" asp-items="Model.Warehouses" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="BatchNumber" class="form-label">Số lô</label>
            <input asp-for="BatchNumber" class="form-control" />
            <span asp-validation-for="BatchNumber" class="text-danger"></span>
        </div>
        <div class="col-md-2">
            <label asp-for="Quantity" class="form-label">Số lượng</label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="ImportedDate" class="form-label">Ngày nhập</label>
            <input asp-for="ImportedDate" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="ExpiryDate" class="form-label">Hạn sử dụng</label>
            <input asp-for="ExpiryDate" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Lưu lô thuốc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
