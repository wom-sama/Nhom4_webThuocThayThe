@model Nhom4WebThuocThayThe.ViewModels.Search.DrugSearchPageViewModel

@{
    ViewData["Title"] = "Tra cứu thuốc";
}

<section class="workspace-heading public-results-heading mb-4">
    <div class="page-kicker"><span class="live-dot" aria-hidden="true"></span>Tra cứu công khai</div>
    <h1 class="page-title">Tra cứu thuốc và tình trạng sẵn có</h1>
</section>

<form method="get" class="app-surface filter-panel filter-panel-v3 mb-4">
    <div class="search-field-primary">
        <label asp-for="Keyword" class="form-label">Từ khóa</label>
        <div class="input-icon-wrap">
            <i data-lucide="search" class="app-icon" aria-hidden="true"></i>
            <input asp-for="Keyword" class="form-control" placeholder="Tên thuốc hoặc hoạt chất" />
        </div>
    </div>
    <div>
        <label asp-for="CategoryId" class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
            <option value="">Tất cả danh mục</option>
        </select>
    </div>
    <div>
        <button type="submit" class="btn btn-primary w-100 icon-button-label"><i data-lucide="search" class="app-icon" aria-hidden="true"></i><span>Tìm thuốc</span></button>
    </div>
</form>

@if (!Model.Results.Any())
{
    <div class="empty-state">Không tìm thấy thuốc phù hợp. Hãy thử tìm theo hoạt chất hoặc danh mục điều trị.</div>
}
else
{
    <div class="section-heading result-heading-v3">
        <div>
            <h2 class="h4">Kết quả phù hợp</h2>
        </div>
        <span class="result-count">@Model.Results.Count thuốc</span>
    </div>

    <div class="result-grid result-list-v3">
        @foreach (var item in Model.Results)
        {
            <article class="drug-card drug-result-row @(item.StockQuantity <= 0 ? "is-stockout" : "is-available")">
                <div class="drug-result-status" aria-hidden="true"><i data-lucide="@(item.StockQuantity <= 0 ? "package-x" : "package-check")"></i></div>
                <div class="drug-result-main">
                    <div class="drug-card-header">
                        <div>
                            <h2 class="drug-title">@item.Name</h2>
                            <div class="drug-meta">
                                <span>@item.Strength</span>
                                <span>@item.Category</span>
                                <span>@item.DosageForm</span>
                                <span>@item.Manufacturer</span>
                            </div>
                        </div>
                    </div>
                    <div class="drug-meta drug-result-tags">
                        @if (item.PrescriptionRequired)
                        {
                            <span class="status-badge is-warning">Cần kê đơn</span>
                        }
                        else
                        {
                            <span class="status-badge is-info">Không kê đơn</span>
                        }
                    </div>
                </div>
                <div class="drug-result-decision">
                    @if (item.StockQuantity <= 0)
                    {
                        <span class="status-badge is-danger">Hết hàng</span>
                    }
                    else
                    {
                        <span class="status-badge is-success">@item.StockQuantity trong kho</span>
                    }
                    <strong class="drug-result-price">@item.Price.ToString("N0") VND</strong>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary icon-button-label"><span>Chi tiết</span><i data-lucide="arrow-right" class="app-icon" aria-hidden="true"></i></a>
                </div>
            </article>
        }
    </div>
}
