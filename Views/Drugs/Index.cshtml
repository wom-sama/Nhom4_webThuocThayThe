@model Nhom4WebThuocThayThe.ViewModels.Search.DrugSearchPageViewModel

@{
    ViewData["Title"] = "Tra cứu thuốc";
}

<section class="mb-4">
    <div class="page-kicker">Tra cứu công khai</div>
    <h1 class="page-title">Tra cứu thuốc và tình trạng sẵn có</h1>
    <p class="page-description">Nhập tên thuốc, hoạt chất hoặc danh mục để xem thuốc phù hợp, tồn kho và cảnh báo kê đơn.</p>
</section>

<form method="get" class="app-surface filter-panel mb-4">
    <div>
        <label asp-for="Keyword" class="form-label">Từ khóa</label>
        <input asp-for="Keyword" class="form-control" placeholder="Nhập tên thuốc, hoạt chất, danh mục..." />
    </div>
    <div>
        <label asp-for="CategoryId" class="form-label">Danh mục</label>
        <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
            <option value="">Tất cả danh mục</option>
        </select>
    </div>
    <div>
        <button type="submit" class="btn btn-primary w-100">Tìm thuốc</button>
    </div>
</form>

@if (!Model.Results.Any())
{
    <div class="empty-state">Không tìm thấy thuốc phù hợp. Hãy thử tìm theo hoạt chất hoặc danh mục điều trị.</div>
}
else
{
    <div class="section-heading">
        <h2 class="h4">Kết quả phù hợp</h2>
        <span class="muted-copy">@Model.Results.Count thuốc</span>
    </div>

    <div class="result-grid">
        @foreach (var item in Model.Results)
        {
            <article class="drug-card">
                <div class="drug-card-header">
                    <div>
                        <h2 class="drug-title">@item.Name</h2>
                        <div class="drug-meta">
                            <span>@item.Strength</span>
                            <span>@item.DosageForm</span>
                            <span>@item.Manufacturer</span>
                        </div>
                    </div>
                    @if (item.StockQuantity <= 0)
                    {
                        <span class="status-badge is-danger">Hết hàng</span>
                    }
                    else
                    {
                        <span class="status-badge is-success">@item.StockQuantity trong kho</span>
                    }
                </div>
                <div class="drug-meta">
                    <span>@item.Category</span>
                    @if (item.PrescriptionRequired)
                    {
                        <span class="status-badge is-warning">Cần kê đơn</span>
                    }
                    else
                    {
                        <span class="status-badge is-info">Không kê đơn</span>
                    }
                </div>
                <div class="d-flex justify-content-between align-items-center gap-2">
                    <span class="muted-copy">@item.Price.ToString("N0") VND</span>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                </div>
            </article>
        }
    </div>
}
