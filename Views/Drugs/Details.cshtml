@model Nhom4WebThuocThayThe.ViewModels.Search.DrugDetailViewModel

@{
    ViewData["Title"] = Model.Name;
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Ho so thuoc</div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-description">@Model.Strength - @Model.DosageForm - @Model.Manufacturer</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">&lt; Quay lai</a>
</section>

<section class="detail-grid">
    <div class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Thong tin duoc ly</h2>
            @if (Model.PrescriptionRequired)
            {
                <span class="status-badge is-warning">Can ke don</span>
            }
            else
            {
                <span class="status-badge is-info">Khong ke don</span>
            }
        </div>

        <dl class="detail-list">
            <div class="detail-row">
                <dt>Hoat chat</dt>
                <dd>
                    <strong>@Model.ActiveIngredient</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveIngredientWarning))
                    {
                        <div class="muted-copy">@Model.ActiveIngredientWarning</div>
                    }
                </dd>
            </div>
            <div class="detail-row">
                <dt>Danh muc</dt>
                <dd>@Model.Category</dd>
            </div>
            <div class="detail-row">
                <dt>Gia ban</dt>
                <dd>@Model.Price.ToString("N0") VND / @Model.Unit</dd>
            </div>
            <div class="detail-row">
                <dt>Mo ta</dt>
                <dd>@Model.Description</dd>
            </div>
            <div class="detail-row">
                <dt>Cach dung</dt>
                <dd>@Model.Usage</dd>
            </div>
            <div class="detail-row">
                <dt>Chong chi dinh</dt>
                <dd>@Model.Contraindications</dd>
            </div>
        </dl>
    </div>

    <aside class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Ton kho</h2>
            @if (Model.StockQuantity <= 0)
            {
                <span class="status-badge is-danger">Het hang</span>
            }
            else
            {
                <span class="status-badge is-success">@Model.StockQuantity kha dung</span>
            }
        </div>
        <p class="muted-copy">Trang thai nay tinh theo cac lo con so luong va chua qua han.</p>

        <h3 class="h5 mt-4">Thuoc thay the cung hoat chat</h3>
        @if (!Model.Alternatives.Any())
        {
            <div class="empty-state">Chua co thuoc thay the phu hop trong du lieu hien tai.</div>
        }
        else
        {
            <div class="stack-list">
                @foreach (var item in Model.Alternatives)
                {
                    <a asp-action="Details" asp-route-id="@item.Id" class="stack-item">
                        <span>
                            <strong>@item.Name</strong>
                            <span>@item.Strength - @item.Manufacturer</span>
                        </span>
                        @if (item.StockQuantity <= 0)
                        {
                            <span class="status-badge is-danger">Het hang</span>
                        }
                        else
                        {
                            <span class="status-badge is-success">@item.StockQuantity</span>
                        }
                    </a>
                }
            </div>
        }
    </aside>
</section>
