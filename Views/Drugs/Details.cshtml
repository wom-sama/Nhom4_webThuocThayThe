@model Nhom4WebThuocThayThe.ViewModels.Search.DrugDetailViewModel

@{
    ViewData["Title"] = Model.Name;
    var hasAlternatives = Model.Alternatives.Any();
}

<section class="action-bar drug-detail-heading">
    <div>
        <div class="page-kicker">Hồ sơ thuốc</div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-description">@Model.Strength · @Model.DosageForm · @Model.Manufacturer</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary icon-button-label">
        <i data-lucide="arrow-left" class="app-icon" aria-hidden="true"></i><span>Quay lại</span>
    </a>
</section>

<section class="decision-summary @(Model.StockQuantity <= 0 ? "is-stockout" : "is-available")" aria-labelledby="availability-heading">
    <div class="decision-summary-icon" aria-hidden="true">
        <i data-lucide="@(Model.StockQuantity <= 0 ? "package-x" : "package-check")"></i>
    </div>
    <div>
        <div class="decision-label">Tình trạng hiện tại</div>
        <h2 id="availability-heading" class="h4 mb-1">
            @if (Model.StockQuantity <= 0)
            {
                <text>Hết hàng · Có @Model.Alternatives.Count phương án thay thế</text>
            }
            else
            {
                <text>Còn @Model.StockQuantity đơn vị khả dụng</text>
            }
        </h2>
    </div>
    @if (Model.StockQuantity <= 0 && hasAlternatives)
    {
        <a href="#recommendations" class="btn btn-primary icon-button-label">
            <i data-lucide="git-compare-arrows" class="app-icon" aria-hidden="true"></i><span>Xem đề xuất</span>
        </a>
    }
</section>

<section class="detail-grid detail-grid-v3">
    <div class="app-surface detail-information">
        <div class="section-heading">
            <div>
                <h2 class="h4">Thông tin thuốc</h2>
            </div>
            @if (Model.PrescriptionRequired)
            {
                <span class="status-badge is-warning">Cần kê đơn</span>
            }
            else
            {
                <span class="status-badge is-info">Không kê đơn</span>
            }
        </div>

        <dl class="detail-list detail-list-primary">
            <div class="detail-row"><dt>Hoạt chất</dt><dd><strong>@Model.ActiveIngredient</strong>@if (!string.IsNullOrWhiteSpace(Model.ActiveIngredientWarning)){<div class="muted-copy">@Model.ActiveIngredientWarning</div>}</dd></div>
            <div class="detail-row"><dt>Nhóm thuốc</dt><dd>@Model.Category</dd></div>
            <div class="detail-row"><dt>Giá tham khảo</dt><dd>@Model.Price.ToString("N0") VND / @Model.Unit</dd></div>
        </dl>

        <details class="pharmacology-disclosure">
            <summary><span><i data-lucide="book-open" class="app-icon" aria-hidden="true"></i>Thông tin dược lý chi tiết</span><i data-lucide="chevron-down" class="app-icon disclosure-chevron" aria-hidden="true"></i></summary>
            <dl class="detail-list mt-3">
                <div class="detail-row"><dt>Mô tả</dt><dd>@Model.Description</dd></div>
                <div class="detail-row"><dt>Cách dùng</dt><dd>@Model.Usage</dd></div>
                <div class="detail-row"><dt>Chống chỉ định</dt><dd>@Model.Contraindications</dd></div>
            </dl>
        </details>
    </div>

    <aside id="recommendations" class="app-surface recommendation-panel" aria-labelledby="recommendations-heading">
        <div class="section-heading">
            <div>
                <h2 id="recommendations-heading" class="h4">Thuốc thay thế đề xuất</h2>
            </div>
            <span class="status-badge @(Model.StockQuantity <= 0 ? "is-danger" : "is-success")">
                @(Model.StockQuantity <= 0 ? "Hết hàng" : $"Còn {Model.StockQuantity}")
            </span>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SafetyProfileName))
        {
            <div class="safety-profile">
                <strong><i data-lucide="shield-check" class="app-icon" aria-hidden="true"></i>Hồ sơ an toàn: @Model.SafetyProfileName</strong>
                <span>@Model.SafetyProfileNote</span>
            </div>
        }

        @if (!hasAlternatives)
        {
            <div class="empty-state"><i data-lucide="package-search" class="app-icon" aria-hidden="true"></i><span>Chưa có thuốc thay thế phù hợp trong dữ liệu hiện tại.</span></div>
        }
        else
        {
            <form id="ai-explanation-token" class="visually-hidden" aria-hidden="true">@Html.AntiForgeryToken()</form>
            <div class="stack-list recommendation-list-v3">
                @{ var recommendationIndex = 0; }
                @foreach (var item in Model.Alternatives)
                {
                    var primaryReasons = item.Reasons.Take(3).ToArray();
                    var additionalReasons = item.Reasons.Skip(3).ToArray();
                    var isPrimaryRecommendation = recommendationIndex == 0;
                    <article class="recommendation-card @(isPrimaryRecommendation ? "is-primary-recommendation" : string.Empty)">
                        @if (isPrimaryRecommendation)
                        {
                            <div class="recommendation-rank"><i data-lucide="badge-check" class="app-icon" aria-hidden="true"></i>Ưu tiên số 1</div>
                        }
                        <div class="recommendation-topline">
                            <div>
                                <a asp-action="Details" asp-route-id="@item.Id"><strong>@item.Name</strong></a>
                                <span>@item.Strength · @item.DosageForm · @item.Manufacturer</span>
                            </div>
                            <div class="score-chip"><strong>@item.Score</strong><span>@item.ScoreLabel</span></div>
                        </div>

                        <div class="recommendation-signals" aria-label="Tín hiệu quyết định">
                            <span class="decision-signal @(item.StockQuantity > 0 ? "is-positive" : "is-negative")"><i data-lucide="@(item.StockQuantity > 0 ? "package-check" : "package-x")" class="app-icon" aria-hidden="true"></i>@(item.StockQuantity > 0 ? $"Còn {item.StockQuantity}" : "Hết hàng")</span>
                            <span class="decision-signal @(item.HasHighRiskAlert ? "is-negative" : "is-positive")"><i data-lucide="@(item.HasHighRiskAlert ? "shield-alert" : "shield-check")" class="app-icon" aria-hidden="true"></i>@(item.HasHighRiskAlert ? "Có cảnh báo cao" : "Không cảnh báo cao")</span>
                            @if (item.PrescriptionRequired){<span class="decision-signal is-warning"><i data-lucide="file-warning" class="app-icon" aria-hidden="true"></i>Cần kê đơn</span>}
                        </div>

                        <ul class="reason-list reason-list-primary">
                            @foreach (var reason in primaryReasons){<li>@reason</li>}
                        </ul>
                        @if (additionalReasons.Any())
                        {
                            <details class="reason-disclosure">
                                <summary>Xem thêm @additionalReasons.Length lý do <i data-lucide="chevron-down" class="app-icon disclosure-chevron" aria-hidden="true"></i></summary>
                                <ul class="reason-list mt-2">@foreach (var reason in additionalReasons){<li>@reason</li>}</ul>
                            </details>
                        }

                        @if (item.Alerts.Any())
                        {
                            <div class="alert-stack">
                                @foreach (var alert in item.Alerts)
                                {
                                    var alertClass = alert.Severity == "High" ? "is-danger" : alert.Severity == "Medium" ? "is-warning" : "is-info";
                                    <div class="safety-alert @alertClass"><strong>@alert.Title</strong><span>@alert.Message</span></div>
                                }
                            </div>
                        }

                        <div class="ai-explanation-control">
                            <button type="button" class="btn btn-sm btn-outline-secondary js-ai-explanation icon-button-label"
                                    data-source-id="@Model.Id" data-candidate-id="@item.Id" data-endpoint="@Url.Action("ExplainAlternative")"
                                    aria-controls="ai-explanation-@item.Id" aria-expanded="false">
                                <i data-lucide="sparkles" class="app-icon" aria-hidden="true"></i><span>Giải thích bằng AI (tùy chọn)</span>
                            </button>
                            <div id="ai-explanation-@item.Id" class="ai-explanation-panel" aria-live="polite" hidden></div>
                        </div>
                    </article>
                    recommendationIndex++;
                }
            </div>
            <p class="ai-safety-note"><i data-lucide="info" class="app-icon" aria-hidden="true"></i>AI chỉ diễn giải kết quả khi được yêu cầu; điểm, cảnh báo và quyết định chuyên môn vẫn là nguồn chính.</p>
        }
    </aside>
</section>
