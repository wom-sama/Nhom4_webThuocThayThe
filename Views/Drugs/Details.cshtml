@model Nhom4WebThuocThayThe.ViewModels.Search.DrugDetailViewModel

@{
    ViewData["Title"] = Model.Name;
}

<section class="action-bar">
    <div>
        <div class="page-kicker">Hồ sơ thuốc</div>
        <h1 class="page-title">@Model.Name</h1>
        <p class="page-description">@Model.Strength - @Model.DosageForm - @Model.Manufacturer</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
</section>

<section class="detail-grid">
    <div class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Thông tin dược lý</h2>
            @if (Model.PrescriptionRequired)
            {
                <span class="status-badge is-warning">Cần kê đơn</span>
            }
            else
            {
                <span class="status-badge is-info">Không kê đơn</span>
            }
        </div>

        <dl class="detail-list">
            <div class="detail-row">
                <dt>Hoạt chất</dt>
                <dd>
                    <strong>@Model.ActiveIngredient</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.ActiveIngredientWarning))
                    {
                        <div class="muted-copy">@Model.ActiveIngredientWarning</div>
                    }
                </dd>
            </div>
            <div class="detail-row">
                <dt>Danh mục</dt>
                <dd>@Model.Category</dd>
            </div>
            <div class="detail-row">
                <dt>Giá bán</dt>
                <dd>@Model.Price.ToString("N0") VND / @Model.Unit</dd>
            </div>
            <div class="detail-row">
                <dt>Mô tả</dt>
                <dd>@Model.Description</dd>
            </div>
            <div class="detail-row">
                <dt>Cách dùng</dt>
                <dd>@Model.Usage</dd>
            </div>
            <div class="detail-row">
                <dt>Chống chỉ định</dt>
                <dd>@Model.Contraindications</dd>
            </div>
        </dl>
    </div>

    <aside class="app-surface">
        <div class="section-heading">
            <h2 class="h4">Tồn kho</h2>
            @if (Model.StockQuantity <= 0)
            {
                <span class="status-badge is-danger">Hết hàng</span>
            }
            else
            {
                <span class="status-badge is-success">@Model.StockQuantity khả dụng</span>
            }
        </div>
        <p class="muted-copy">Trạng thái này tính theo các lô còn số lượng và chưa quá hạn.</p>

        @if (!string.IsNullOrWhiteSpace(Model.SafetyProfileName))
        {
            <div class="safety-profile">
                <strong>Hồ sơ an toàn: @Model.SafetyProfileName</strong>
                <span>@Model.SafetyProfileNote</span>
            </div>
        }

        <h3 class="h5 mt-4">Thuốc thay thế đề xuất</h3>
        @if (!Model.Alternatives.Any())
        {
            <div class="empty-state">Chưa có thuốc thay thế phù hợp trong dữ liệu hiện tại.</div>
        }
        else
        {
            <form id="ai-explanation-token" class="visually-hidden" aria-hidden="true">
                @Html.AntiForgeryToken()
            </form>
            <div class="stack-list">
                @foreach (var item in Model.Alternatives)
                {
                    <article class="recommendation-card">
                        <div class="recommendation-topline">
                            <div>
                                <a asp-action="Details" asp-route-id="@item.Id"><strong>@item.Name</strong></a>
                                <span>@item.Strength - @item.DosageForm - @item.Manufacturer</span>
                            </div>
                            <div class="score-chip">
                                <strong>@item.Score</strong>
                                <span>@item.ScoreLabel</span>
                            </div>
                        </div>
                        <div class="drug-meta">
                            <span>@item.ActiveIngredient</span>
                            @if (item.StockQuantity <= 0)
                            {
                                <span class="status-badge is-danger">Hết hàng</span>
                            }
                            else
                            {
                                <span class="status-badge is-success">@item.StockQuantity khả dụng</span>
                            }
                            @if (item.PrescriptionRequired)
                            {
                                <span class="status-badge is-warning">Cần kê đơn</span>
                            }
                        </div>
                        <ul class="reason-list">
                            @foreach (var reason in item.Reasons)
                            {
                                <li>@reason</li>
                            }
                        </ul>
                        @if (item.Alerts.Any())
                        {
                            <div class="alert-stack">
                                @foreach (var alert in item.Alerts)
                                {
                                    var alertClass = alert.Severity == "High" ? "is-danger" : alert.Severity == "Medium" ? "is-warning" : "is-info";
                                    <div class="safety-alert @alertClass">
                                        <strong>@alert.Title</strong>
                                        <span>@alert.Message</span>
                                    </div>
                                }
                            </div>
                        }
                        <div class="ai-explanation-control">
                            <button type="button"
                                    class="btn btn-sm btn-outline-secondary js-ai-explanation"
                                    data-source-id="@Model.Id"
                                    data-candidate-id="@item.Id"
                                    data-endpoint="@Url.Action("ExplainAlternative")"
                                    aria-controls="ai-explanation-@item.Id"
                                    aria-expanded="false">
                                Giải thích có hỗ trợ AI
                            </button>
                            <div id="ai-explanation-@item.Id"
                                 class="ai-explanation-panel"
                                 aria-live="polite"
                                 hidden></div>
                        </div>
                    </article>
                }
            </div>
            <p class="ai-safety-note">
                AI chỉ giải thích kết quả từ bộ quy tắc khi bạn yêu cầu. Điểm, cảnh báo an toàn và quyết định của dược sĩ vẫn là nguồn tham chiếu chính; hệ thống không gửi hồ sơ cá nhân đến AI.
            </p>
        }
    </aside>
</section>
